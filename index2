<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>ES Futures Dashboard</title>
<script src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#06080d;--panel:#0a0d14;--border:#161c28;--dim:#2a3448;
  --label:#4a5a78;--text:#8090b0;--white:#ccdaee;
  --cyan:#00c8f0;--green:#00d97e;--red:#f03d5f;--amber:#f0a500;--purple:#a078f0;
  --font-mono:'IBM Plex Mono',monospace;--font-sans:'IBM Plex Sans',sans-serif;
}
html,body{width:100%;height:100%;background:var(--bg);color:var(--white);font-family:var(--font-mono);overflow:hidden}

/* NAV */
#nav{position:fixed;top:0;left:0;right:0;height:44px;z-index:100;
  background:rgba(6,8,13,0.97);border-bottom:1px solid var(--border);
  display:flex;align-items:center;padding:0 16px;gap:0;backdrop-filter:blur(8px)}
.logo{font-size:12px;font-weight:600;color:var(--green);letter-spacing:3px;margin-right:20px;white-space:nowrap}
.tab{height:44px;line-height:44px;padding:0 16px;font-size:10px;letter-spacing:1.5px;
  color:var(--label);cursor:pointer;border-bottom:2px solid transparent;
  text-transform:uppercase;transition:color .2s,border-color .2s;white-space:nowrap}
.tab:hover{color:var(--text)}
.tab.on{color:var(--white);border-bottom-color:var(--green)}
.nav-right{margin-left:auto;display:flex;align-items:center;gap:16px}
.nav-price{font-size:14px;font-weight:600;color:var(--green)}
.nav-session{font-size:10px;letter-spacing:1px}
.nav-time{font-size:10px;color:var(--label)}
.live-dot{width:6px;height:6px;border-radius:50%;background:var(--green);display:inline-block;margin-right:6px;animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

/* PANELS */
#panels{position:fixed;top:44px;left:0;right:0;bottom:0}
.panel{position:absolute;inset:0;display:none;overflow:hidden}
.panel.on{display:block}
#p-greek{overflow-y:auto;overflow-x:hidden;padding:14px 16px;background:var(--bg)}

/* HEATMAP OVERLAY */
#crosshair-h{position:fixed;width:100%;height:1px;background:rgba(255,255,255,.25);pointer-events:none;display:none;z-index:50}
#crosshair-v{position:fixed;height:100%;width:1px;background:rgba(255,255,255,.25);pointer-events:none;display:none;z-index:50}
#crosshair-price{position:fixed;background:var(--bg);border:1px solid var(--green);color:var(--green);
  font-size:10px;padding:2px 7px;pointer-events:none;display:none;z-index:50;font-family:var(--font-mono)}
#crosshair-time{position:fixed;background:var(--bg);border:1px solid var(--border);color:var(--text);
  font-size:10px;padding:2px 7px;pointer-events:none;display:none;z-index:50;font-family:var(--font-mono)}

/* GREEKS LAYOUT */
.section-label{font-size:9px;letter-spacing:2px;color:var(--label);text-transform:uppercase;margin-bottom:8px;padding-left:2px}

.kpi-row{display:flex;gap:0;border:1px solid var(--border);border-radius:4px;overflow:hidden;margin-bottom:14px;background:var(--panel)}
.kpi-cell{flex:1;padding:12px 16px;border-right:1px solid var(--border)}
.kpi-cell:last-child{border-right:none}
.kpi-val{font-size:18px;font-weight:500;line-height:1;margin-bottom:5px}
.kpi-lbl{font-size:8px;letter-spacing:1.5px;color:var(--label);text-transform:uppercase}
.kpi-sub{font-size:9px;color:var(--dim);margin-top:3px}

.charts-2col{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.charts-3col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:10px}
.chart-box{background:var(--panel);border:1px solid var(--border);border-radius:4px;overflow:hidden}
.chart-box-full{background:var(--panel);border:1px solid var(--border);border-radius:4px;overflow:hidden;margin-bottom:10px}

.greeks-cards{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:14px}
.greek-card{background:var(--panel);border:1px solid var(--border);border-radius:4px;padding:12px 14px}
.greek-card-name{font-size:11px;font-weight:500;margin-bottom:4px;color:var(--white)}
.greek-card-val{font-size:20px;font-weight:600;margin-bottom:6px}
.greek-card-bar{height:3px;background:var(--dim);border-radius:2px;margin-bottom:8px;overflow:hidden}
.greek-card-bar-fill{height:100%;border-radius:2px;transition:width .8s ease}
.greek-card-desc{font-size:10px;color:var(--text);line-height:1.6;font-family:var(--font-sans)}
.badge{display:inline-block;font-size:9px;padding:2px 7px;border-radius:3px;margin-left:6px;letter-spacing:.5px;vertical-align:middle}
.badge-bull{background:rgba(0,217,126,.15);color:var(--green)}
.badge-bear{background:rgba(240,61,95,.15);color:var(--red)}
.badge-neutral{background:rgba(74,90,120,.2);color:var(--text)}

.strike-table{width:100%;border-collapse:collapse;font-size:11px}
.strike-table th{font-size:9px;letter-spacing:1.5px;color:var(--label);text-transform:uppercase;
  padding:6px 12px;text-align:left;border-bottom:1px solid var(--border)}
.strike-table td{padding:7px 12px;border-bottom:1px solid rgba(22,28,40,.6);color:var(--white)}
.strike-table tr:last-child td{border-bottom:none}
.strike-table .muted{color:var(--label)}

.bias-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px}
.bias-card{border:1px solid var(--border);border-radius:4px;padding:12px 14px}
.bias-card-label{font-size:9px;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:5px}
.bias-card-val{font-size:13px;font-weight:500}

.footer-note{font-size:9px;color:var(--label);padding:12px 0 4px;border-top:1px solid var(--border);text-align:center;letter-spacing:.5px}

/* LOADING OVERLAY */
#loading{position:fixed;inset:0;background:var(--bg);z-index:200;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:16px;transition:opacity .5s}
#loading.gone{opacity:0;pointer-events:none}
.loading-title{font-size:11px;letter-spacing:4px;color:var(--green);text-transform:uppercase}
.loading-bar-wrap{width:200px;height:2px;background:var(--border);border-radius:1px}
.loading-bar{height:100%;width:0%;background:var(--green);border-radius:1px;transition:width .3s}
.loading-sub{font-size:9px;color:var(--label);letter-spacing:1px}

/* REFRESH badge */
#refresh-badge{position:fixed;bottom:8px;right:12px;font-size:9px;color:var(--dim);z-index:99;letter-spacing:.5px}
</style>
</head>
<body>

<div id="loading">
  <div class="loading-title">ES Dashboard</div>
  <div class="loading-bar-wrap"><div class="loading-bar" id="lbar"></div></div>
  <div class="loading-sub" id="lsub">Initializing...</div>
</div>

<div id="nav">
  <div class="logo">ES<span style="color:var(--label);font-weight:300">FUT</span></div>
  <div class="tab on"  onclick="showTab('heat',this)">Heatmap</div>
  <div class="tab"     onclick="showTab('vol',this)">Vol Surface</div>
  <div class="tab"     onclick="showTab('greek',this)">Greeks</div>
  <div class="nav-right">
    <span class="nav-time" id="nav-time"></span>
    <span class="nav-price" id="nav-price">—</span>
    <span class="nav-session" id="nav-session">—</span>
    <span style="font-size:10px;color:var(--label)"><span class="live-dot"></span>LIVE</span>
  </div>
</div>

<div id="panels">
  <div class="panel on" id="p-heat"></div>
  <div class="panel"    id="p-vol"></div>
  <div class="panel"    id="p-greek">

    <div class="section-label">Key metrics</div>
    <div class="kpi-row">
      <div class="kpi-cell">
        <div class="kpi-val" id="kpi-es" style="color:var(--white)">—</div>
        <div class="kpi-lbl">ES Futures</div>
      </div>
      <div class="kpi-cell">
        <div class="kpi-val" id="kpi-gex" style="color:var(--green)">—</div>
        <div class="kpi-lbl">Net GEX</div>
        <div class="kpi-sub" id="kpi-gex-sub">—</div>
      </div>
      <div class="kpi-cell">
        <div class="kpi-val" id="kpi-vanna" style="color:var(--cyan)">—</div>
        <div class="kpi-lbl">Net Vanna</div>
        <div class="kpi-sub" id="kpi-vanna-sub">—</div>
      </div>
      <div class="kpi-cell">
        <div class="kpi-val" id="kpi-iv" style="color:var(--amber)">—</div>
        <div class="kpi-lbl">ATM IV (30d)</div>
        <div class="kpi-sub" id="kpi-iv-sub">—</div>
      </div>
      <div class="kpi-cell">
        <div class="kpi-val" id="kpi-flip" style="color:var(--red)">—</div>
        <div class="kpi-lbl">γ Flip Level</div>
        <div class="kpi-sub">ES equivalent</div>
      </div>
      <div class="kpi-cell">
        <div class="kpi-val" id="kpi-charm" style="color:var(--purple)">—</div>
        <div class="kpi-lbl">Net Charm</div>
        <div class="kpi-sub" id="kpi-charm-sub">—</div>
      </div>
    </div>

    <div class="section-label">Greeks explained</div>
    <div class="greeks-cards">
      <div class="greek-card">
        <div class="greek-card-name">Vanna <span class="badge badge-bull" id="vanna-badge">Bullish</span></div>
        <div class="greek-card-val" id="vanna-val" style="color:var(--cyan)">—</div>
        <div class="greek-card-bar"><div class="greek-card-bar-fill" id="vanna-bar" style="width:0%;background:var(--cyan)"></div></div>
        <div class="greek-card-desc">Measures how dealer delta changes when IV moves. IV compressing = dealers sell futures. IV spiking = dealers buy futures. Biggest mechanical flow driver in ES.</div>
      </div>
      <div class="greek-card">
        <div class="greek-card-name">Gamma <span class="badge badge-neutral" id="gamma-badge">Stabilizing</span></div>
        <div class="greek-card-val" id="gamma-val" style="color:var(--green)">—</div>
        <div class="greek-card-bar"><div class="greek-card-bar-fill" id="gamma-bar" style="width:0%;background:var(--green)"></div></div>
        <div class="greek-card-desc">Dealers long gamma near key strikes sell rallies and buy dips to stay neutral. Suppresses realized vol and pins price to strike clusters heading into OPEX.</div>
      </div>
      <div class="greek-card">
        <div class="greek-card-name">Charm <span class="badge badge-bear" id="charm-badge">Headwind</span></div>
        <div class="greek-card-val" id="charm-val" style="color:var(--purple)">—</div>
        <div class="greek-card-bar"><div class="greek-card-bar-fill" id="charm-bar" style="width:0%;background:var(--purple)"></div></div>
        <div class="greek-card-desc">Delta decay over time. As near-expiry options lose delta, dealers must sell futures to rebalance. Creates a persistent directional bleed through the session.</div>
      </div>
      <div class="greek-card">
        <div class="greek-card-name">Delta <span class="badge badge-neutral">Net Long</span></div>
        <div class="greek-card-val" id="delta-val" style="color:var(--amber)">—</div>
        <div class="greek-card-bar"><div class="greek-card-bar-fill" id="delta-bar" style="width:0%;background:var(--amber)"></div></div>
        <div class="greek-card-desc">Aggregate dealer directional exposure. Net long means dealers hedge by selling futures — creates a ceiling. Net short means they buy futures — creates a floor.</div>
      </div>
    </div>

    <div class="charts-2col">
      <div>
        <div class="section-label">GEX by strike</div>
        <div class="chart-box"><div id="gc-gex" style="height:260px"></div></div>
      </div>
      <div>
        <div class="section-label">Vanna profile</div>
        <div class="chart-box"><div id="gc-van" style="height:260px"></div></div>
      </div>
    </div>

    <div class="charts-2col">
      <div>
        <div class="section-label">Gamma profile</div>
        <div class="chart-box"><div id="gc-gam" style="height:240px"></div></div>
      </div>
      <div>
        <div class="section-label">Charm profile</div>
        <div class="chart-box"><div id="gc-ch" style="height:240px"></div></div>
      </div>
    </div>

    <div class="section-label">Key strike levels</div>
    <div class="chart-box-full" style="padding:0">
      <table class="strike-table">
        <thead>
          <tr>
            <th>Strike (ES)</th>
            <th>Type</th>
            <th>Net Gamma</th>
            <th>Vanna Exp.</th>
            <th>Signal</th>
          </tr>
        </thead>
        <tbody id="strike-tbody">
          <tr><td colspan="5" style="color:var(--label);text-align:center;padding:16px">Loading...</td></tr>
        </tbody>
      </table>
    </div>

    <div class="section-label">IV term structure</div>
    <div class="chart-box-full"><div id="gc-term" style="height:200px"></div></div>

    <div class="section-label" style="margin-top:4px">Weekly bias</div>
    <div class="bias-row">
      <div class="bias-card" id="bias-vanna" style="border-color:rgba(0,200,240,.2);background:rgba(0,200,240,.04)">
        <div class="bias-card-label" style="color:var(--cyan)">Vanna bias</div>
        <div class="bias-card-val" id="bias-vanna-val" style="color:var(--cyan)">—</div>
      </div>
      <div class="bias-card" id="bias-gamma" style="border-color:rgba(0,217,126,.2);background:rgba(0,217,126,.04)">
        <div class="bias-card-label" style="color:var(--green)">Gamma regime</div>
        <div class="bias-card-val" id="bias-gamma-val" style="color:var(--green)">—</div>
      </div>
      <div class="bias-card" style="border-color:var(--border)">
        <div class="bias-card-label" style="color:var(--label)">Charm drag</div>
        <div class="bias-card-val" id="bias-charm-val" style="color:var(--text)">—</div>
      </div>
    </div>

    <div class="footer-note">All data sourced live via Yahoo Finance · SPY options chain · ES/SPY ratio recalibrated each load · Not financial advice</div>
  </div>
</div>

<div id="crosshair-h"></div>
<div id="crosshair-v"></div>
<div id="crosshair-price"></div>
<div id="crosshair-time"></div>
<div id="refresh-badge">next refresh <span id="cd">30</span>s</div>

<script>
// ─────────────────────────────────────────────────────────
// CONFIG
// ─────────────────────────────────────────────────────────
const REFRESH_MS = 30000;

// Multi-proxy fallback — tries each until one works
const PROXY_FNS = [
  u => `https://api.allorigins.win/raw?url=${encodeURIComponent(u)}`,
  u => `https://corsproxy.io/?${encodeURIComponent(u)}`,
  u => `https://thingproxy.freeboard.io/fetch/${u}`,
];
const YF_BASES = [
  'https://query1.finance.yahoo.com',
  'https://query2.finance.yahoo.com',
];

async function fetchYF(path) {
  for (const proxy of PROXY_FNS) {
    for (const base of YF_BASES) {
      try {
        const ctrl = new AbortController();
        const tid  = setTimeout(() => ctrl.abort(), 9000);
        const r    = await fetch(proxy(base + path), {
          signal: ctrl.signal,
          headers: {'Accept':'application/json','X-Requested-With':'XMLHttpRequest'}
        });
        clearTimeout(tid);
        if (!r.ok) continue;
        const txt = await r.text();
        if (!txt || txt.startsWith('<')) continue; // HTML error page
        const d = JSON.parse(txt);
        if (d && (d.chart || d.optionChain || d.quoteResponse)) return d;
      } catch {}
    }
  }
  throw new Error('All proxies failed: ' + path);
}

// ─────────────────────────────────────────────────────────
// LOADING
// ─────────────────────────────────────────────────────────
let loadPct = 0;
function setLoad(pct, msg) {
  loadPct = pct;
  document.getElementById('lbar').style.width = pct + '%';
  document.getElementById('lsub').textContent = msg;
}
function doneLoad() {
  const el = document.getElementById('loading');
  el.classList.add('gone');
  setTimeout(() => el.remove(), 600);
}

// ─────────────────────────────────────────────────────────
// SESSION
// ─────────────────────────────────────────────────────────
function getSession() {
  const now = new Date();
  const et  = new Date(now.toLocaleString('en-US', {timeZone:'America/New_York'}));
  const h   = et.getHours(), m = et.getMinutes(), wd = et.getDay();
  const t   = h * 60 + m;
  if (wd === 0 || wd === 6) return {label:'WEEKEND',   color:'#ff6b35'};
  if (t < 240)              return {label:'OVERNIGHT', color:'#7b68ee'};
  if (t < 570)              return {label:'PRE-MARKET',color:'#f5c518'};
  if (t <= 960)             return {label:'OPEN',      color:'#00d97e'};
  if (t <= 1200)            return {label:'AH',        color:'#ff8c00'};
  return                           {label:'OVERNIGHT', color:'#7b68ee'};
}

function updateClock() {
  const s = getSession();
  document.getElementById('nav-time').textContent =
    new Date().toLocaleTimeString('en-US',{timeZone:'America/New_York',hour:'2-digit',minute:'2-digit',second:'2-digit'}) + ' ET';
  const se = document.getElementById('nav-session');
  se.textContent = s.label; se.style.color = s.color;
}
setInterval(updateClock, 1000); updateClock();

// ─────────────────────────────────────────────────────────
// FETCH HELPERS
// ─────────────────────────────────────────────────────────
async function getSpotPrice() {
  try {
    const d = await fetchYF('/v8/finance/chart/ES=F?interval=1m&range=1d');
    const q = d.chart.result[0].meta;
    return q.regularMarketPrice || q.previousClose;
  } catch {
    try {
      const d = await fetchYF('/v8/finance/chart/SPY?interval=1m&range=1d');
      return d.chart.result[0].meta.regularMarketPrice;
    } catch { return null; }
  }
}

async function getESRatio() {
  try {
    const [es, spy] = await Promise.all([
      fetchYF('/v8/finance/chart/ES=F?interval=1m&range=1d'),
      fetchYF('/v8/finance/chart/SPY?interval=1m&range=1d')
    ]);
    const ep = es.chart.result[0].meta.regularMarketPrice;
    const sp = spy.chart.result[0].meta.regularMarketPrice;
    return ep / sp;
  } catch { return 10.1; }
}

// ─────────────────────────────────────────────────────────
// HEATMAP
// ─────────────────────────────────────────────────────────
async function buildHeatmap() {
  setLoad(10, 'Fetching price data...');
  let df = null, sym = 'ES=F';
  for (const s of ['ES=F','SPY']) {
    try {
      const d = await fetchYF(`/v8/finance/chart/${s}?interval=1m&range=1d`);
      const r = d.chart.result[0];
      if (r.timestamp && r.timestamp.length >= 10) { df = r; sym = s; break; }
    } catch {}
  }
  if (!df) { document.getElementById('p-heat').innerHTML='<div style="padding:4rem;color:#555;text-align:center">No price data available</div>'; return; }

  const ts     = df.timestamp;
  const q      = df.indicators.quote[0];
  const opens  = q.open, highs = q.high, lows = q.low, closes = q.close, vols = q.volume;
  const n      = ts.length;
  const BINS   = 200;
  const ctr    = df.meta.regularMarketPrice || closes[closes.length-1];

  let pLo = Math.min(...lows.filter(Boolean));
  let pHi = Math.max(...highs.filter(Boolean));
  const rng = Math.max(pHi - pLo, ctr * 0.002);
  const pad = rng * 0.12;
  pLo -= pad; pHi += pad;

  const prices = Array.from({length:BINS}, (_,i) => pLo + (pHi-pLo)*i/(BINS-1));
  const pStep  = prices[1] - prices[0];
  const mat    = Array.from({length:BINS}, () => new Float32Array(n));

  for (let i = 0; i < n; i++) {
    const c = closes[i], lo = lows[i], hi = highs[i], v = vols[i];
    if (!c || !v || v <= 0) continue;
    const barRng = Math.max(hi - lo, pStep * 2);
    const sigmaP = Math.max(barRng * 0.5, pStep * 3);
    for (let j = 0; j < BINS; j++) {
      const p = prices[j];
      if (p >= lo && p <= hi) mat[j][i] += v * 0.5;
      mat[j][i] += v * 0.5 * Math.exp(-0.5 * ((p - c) / sigmaP) ** 2);
    }
  }

  // Gaussian blur approximation (box blur)
  const blurTime = 5, blurPrice = 2;
  for (let j = 0; j < BINS; j++) {
    const row = mat[j], tmp = new Float32Array(n);
    for (let i = 0; i < n; i++) {
      let s = 0, cnt = 0;
      for (let d = -blurTime; d <= blurTime; d++) {
        const ii = i + d;
        if (ii >= 0 && ii < n) { s += row[ii]; cnt++; }
      }
      tmp[i] = s / cnt;
    }
    mat[j].set(tmp);
  }

  // Normalize
  let vmax = 0;
  for (let j = 0; j < BINS; j++) for (let i = 0; i < n; i++) {
    const v = Math.log1p(mat[j][i]);
    mat[j][i] = v;
    if (v > vmax) vmax = v;
  }
  const z = [];
  for (let j = 0; j < BINS; j++) {
    const row = [];
    for (let i = 0; i < n; i++) row.push(Math.pow(Math.min(mat[j][i]/Math.max(vmax,1e-9), 1), 0.4));
    z.push(row);
  }

  const step  = Math.max(1, Math.floor(n / 8));
  const xtvs  = [], xttx = [];
  for (let i = 0; i < n; i += step) {
    xtvs.push(i);
    xttx.push(new Date(ts[i]*1000).toLocaleTimeString('en-US',{timeZone:'America/New_York',hour:'2-digit',minute:'2-digit',hour12:false}));
  }
  const ts2 = Math.max(1, Math.floor(BINS / 12));
  const ytvs = [], yttx = [];
  for (let j = 0; j < BINS; j += ts2) { ytvs.push(j); yttx.push('$'+prices[j].toFixed(0)); }

  const crIdx = prices.reduce((bi,p,i) => Math.abs(p-ctr)<Math.abs(prices[bi]-ctr)?i:bi, 0);
  const crPath = closes.map(c => c ? prices.reduce((bi,p,i) => Math.abs(p-c)<Math.abs(prices[bi]-c)?i:bi, 0) : crIdx);

  const layout = {
    title:{text:`ES Futures · Liquidity Heatmap · <span style='color:${getSession().color}'>${getSession().label}</span> · <span style='color:#00d97e'>$${ctr.toFixed(2)}</span>`,
