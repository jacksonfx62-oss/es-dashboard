     line:{color:CYAN,width:1.2},marker:{size:4,color:CYAN},
     hovertemplate:'DTE %{x}<br>%{y:.1f}%<extra>calls</extra>'},
    {type:'scatter',x:dtes,y:putIVs,mode:'lines+markers',name:'puts',
     line:{color:AMBER,width:1.2},marker:{size:4,color:AMBER},
     hovertemplate:'DTE %{x}<br>%{y:.1f}%<extra>puts</extra>'}
  ],{...baseLayout,showlegend:true,
    legend:{bgcolor:'rgba(0,0,0,0)',font:{color:DIM,size:8},x:1,xanchor:'right',y:1.1,orientation:'h'},
    xaxis:{...baseLayout.xaxis,title:{text:'DTE',font:{size:9,color:DIM}}},
    yaxis:{...baseLayout.yaxis,title:{text:'IV %',font:{size:9,color:DIM}}}
  },{responsive:true,displayModeBar:false});

  // Strike table — top 6 by abs GEX
  const topStrikes=strikes.sort((a,b)=>Math.abs(b.ngex)-Math.abs(a.ngex)).slice(0,6)
    .sort((a,b)=>b.strike-a.strike);
  const tbody=document.getElementById('strike-tbody');
  tbody.innerHTML=topStrikes.map(s=>{
    const esK=(s.strike*ratio).toFixed(0);
    const aboveSpot=s.strike>spot;
    const type=aboveSpot?'Call wall':'Put wall';
    const sig=s.ngex>0?'<span class="badge badge-bull">Support</span>':'<span class="badge badge-bear">Resistance</span>';
    if (Math.abs(s.strike-spot)/spot<0.003) return `<tr><td>${esK}</td><td class="muted">Max pain</td><td>${s.ngex.toLocaleString(undefined,{maximumFractionDigits:0})}</td><td>${s.nvanna.toLocaleString(undefined,{maximumFractionDigits:0})}</td><td><span class="badge badge-neutral">Pin zone</span></td></tr>`;
    return `<tr><td>${esK}</td><td class="muted">${type}</td><td>${s.ngex.toLocaleString(undefined,{maximumFractionDigits:0})}</td><td>${s.nvanna.toLocaleString(undefined,{maximumFractionDigits:0})}</td><td>${sig}</td></tr>`;
  }).join('');
}

