let volBuilt=false, greekBuilt=false;
function showTab(name, el) {
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('on'));
  el.classList.add('on');
  document.getElementById('p-'+name).classList.add('on');
  if (name==='vol' && !volBuilt) { volBuilt=true; buildVolSurface(); }
  if (name==='greek' && !greekBuilt) { greekBuilt=true; buildGreeks(); }
  setTimeout(()=>{
    document.querySelectorAll('.plotly-graph-div').forEach(d=>{
      if (window.Plotly) Plotly.relayout(d,{autosize:true});
    });
  },50);
}

// ─────────────────────────────────────────────────────────
// INIT
// ─────────────────────────────────────────────────────────
async function init() {
  try { await buildHeatmap(); } catch(e){ console.warn('heatmap',e); setLoad(40,'Heatmap error, continuing...'); }
  setLoad(100, 'Ready');
  setTimeout(doneLoad, 400);
}

// Refresh countdown
let cd=REFRESH_MS/1000;
setInterval(()=>{ cd--; if(cd<=0) cd=REFRESH_MS/1000; document.getElementById('cd').textContent=cd+'s'; },1000);
setInterval(async ()=>{ try { await buildHeatmap(); } catch{} }, REFRESH_MS);

init();
</script>
