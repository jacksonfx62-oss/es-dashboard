async function buildVolSurface() {
  setLoad(50, 'Fetching options chain...');
  let spot = 0;
  try {
    const d = await fetchYF('/v8/finance/chart/SPY?interval=1d&range=1d');
    spot = d.chart.result[0].meta.regularMarketPrice;
  } catch { spot = 580; }

  // Get expirations
  let expirations = [];
  try {
    const d = await fetchYF('/v7/finance/options/SPY');
    expirations = d.optionChain.result[0].expirationDates.slice(0,10);
  } catch {}

  const rows = [];
  const today = Date.now() / 1000;
  const toFetch = expirations.slice(0, 6);

  for (const exp of toFetch) {
    try {
      const d   = await fetchYF(`/v7/finance/options/SPY?date=${exp}`);
      const res = d.optionChain.result[0];
      const T   = Math.max((exp - today) / (365 * 86400), 1/365);
      for (const opt of [...(res.options[0].calls||[]), ...(res.options[0].puts||[])]) {
        const iv = opt.impliedVolatility;
        const K  = opt.strike;
        if (iv && iv > 0.01 && iv < 3 && K >= spot*0.87 && K <= spot*1.13) {
          rows.push({T, mon: K/spot, iv: iv*100});
        }
      }
    } catch {}
  }

  setLoad(70, 'Building vol surface...');
  if (rows.length < 10) {
    document.getElementById('p-vol').innerHTML='<div style="padding:4rem;color:#555;text-align:center">Not enough IV data — try during market hours</div>';
    return;
  }

  // Grid interpolation
  const nT=40, nM=40;
  const tMin=Math.min(...rows.map(r=>r.T)), tMax=Math.max(...rows.map(r=>r.T));
  const mMin=Math.min(...rows.map(r=>r.mon)), mMax=Math.max(...rows.map(r=>r.mon));
  const tGrid=Array.from({length:nT},(_,i)=>tMin+(tMax-tMin)*i/(nT-1));
  const mGrid=Array.from({length:nM},(_,i)=>mMin+(mMax-mMin)*i/(nM-1));
  const z=[];
  for (let mi=0;mi<nM;mi++) {
    const row=[];
    for (let ti=0;ti<nT;ti++) {
      const tG=tGrid[ti], mG=mGrid[mi];
      let sw=0, sv=0;
      for (const r of rows) {
        const d2=((r.T-tG)/(tMax-tMin+1e-9))**2+((r.mon-mG)/(mMax-mMin+1e-9))**2;
        const w=Math.exp(-d2*20);
        sw+=w; sv+=w*r.iv;
      }
      row.push(sw>0?sv/sw:null);
    }
    z.push(row);
  }
  const xDte=tGrid.map(t=>Math.round(t*365));
  const atmi=mGrid.reduce((bi,m,i)=>Math.abs(m-1)<Math.abs(mGrid[bi]-1)?i:bi,0);

  const el=document.getElementById('p-vol');
  Plotly.newPlot(el,[
    {type:'surface',x:xDte,y:mGrid,z,
     colorscale:[[0,'#0d0221'],[.15,'#1a0a3d'],[.30,'#0b3d91'],[.45,'#006994'],
                 [.55,'#00a878'],[.65,'#f5c518'],[.80,'#ff6b35'],[1,'#f00']],
     opacity:.92,lighting:{ambient:.6,diffuse:.8,specular:.3,roughness:.5},
     colorbar:{title:{text:'IV %',font:{color:'white',size:10}},tickfont:{color:'white',size:9},thickness:10,len:.6},
     hovertemplate:'DTE: %{x:.0f}d<br>Moneyness: %{y:.3f}<br>IV: %{z:.1f}%<extra></extra>'},
    {type:'scatter3d',x:xDte,y:mGrid.map(()=>1.0),z:z[atmi],mode:'lines',
     line:{color:'white',width:3},name:'ATM',
     hovertemplate:'ATM DTE: %{x:.0f}d<br>IV: %{z:.1f}%<extra>ATM</extra>'}
  ],{
    title:{text:`<b>SPY · Implied Volatility Surface</b>  <span style='color:${getSession().color}'>${getSession().label}</span>  <span style='color:#00d97e'>Spot $${spot.toFixed(2)}</span>`,
      font:{color:'white',size:12,family:"'IBM Plex Mono',monospace"},x:.5,xanchor:'center',y:.97},
    scene:{
      xaxis:{title:{text:'DTE'},tickfont:{color:'#aaa',size:9},backgroundcolor:'#080818',gridcolor:'#1a1a2e',showbackground:true},
      yaxis:{title:{text:'Moneyness'},tickfont:{color:'#aaa',size:9},backgroundcolor:'#080818',gridcolor:'#1a1a2e',showbackground:true},
      zaxis:{title:{text:'IV %'},tickfont:{color:'#aaa',size:9},backgroundcolor:'#080818',gridcolor:'#1a1a2e',showbackground:true},
      bgcolor:'#05050f',camera:{eye:{x:-1.5,y:-1.5,z:.8}},aspectratio:{x:1.4,y:1,z:.65}
    },
    paper_bgcolor:'#03030a',font:{color:'white',family:"'IBM Plex Mono',monospace"},
    margin:{l:0,r:0,t:60,b:0},autosize:true
  },{responsive:true,scrollZoom:true,displaylogo:false});
}

