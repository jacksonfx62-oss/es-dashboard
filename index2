// GREEKS
// ─────────────────────────────────────────────────────────
function normPDF(x){return Math.exp(-.5*x*x)/Math.sqrt(2*Math.PI)}
function normCDF(x){
  const a1=.254829592,a2=-.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=.3275911;
  const sign=x<0?-1:1; x=Math.abs(x)/Math.sqrt(2);
  const t=1/(1+p*x);
  return .5*(1+sign*(1-((((a5*t+a4)*t+a3)*t+a2)*t+a1)*t*Math.exp(-x*x)));
}
function bsGreeks(S,K,T,r,q,sig,isCall){
  T=Math.max(T,1e-6); sig=Math.max(sig,.001);
  const d1=(Math.log(S/K)+(r-q+.5*sig*sig)*T)/(sig*Math.sqrt(T));
  const d2=d1-sig*Math.sqrt(T);
  const n1=normPDF(d1), N1=normCDF(d1);
  const eqT=Math.exp(-q*T);
  const delta=isCall?eqT*N1:eqT*(N1-1);
  const gamma=eqT*n1/(S*sig*Math.sqrt(T));
  const vanna=-eqT*n1*d2/(sig*100);
  const cb=eqT*(q*N1-n1*(2*(r-q)*T-d2*sig*Math.sqrt(T))/(2*T*sig*Math.sqrt(T)));
  const charm=(isCall?cb:cb-q*eqT)/365;
  return {delta,gamma,vanna,charm};
}

async function buildGreeks() {
  setLoad(80, 'Computing greeks...');
  let spot=0, ratio=10.1;
  try {
    const [sd,rd]=await Promise.all([
      fetchYF('/v8/finance/chart/SPY?interval=1m&range=1d'),
      getESRatio()
    ]);
    spot=sd.chart.result[0].meta.regularMarketPrice;
    ratio=rd;
  } catch { spot=580; }

  let exps=[];
  try {
    const d=await fetchYF('/v7/finance/options/SPY');
    exps=d.optionChain.result[0].expirationDates.slice(0,8);
  } catch {}

  const today=Date.now()/1000;
  const r=0.045, q=0.013;
  const rows=[];

  for (const exp of exps.slice(0,5)) {
    try {
      const d=await fetchYF(`/v7/finance/options/SPY?date=${exp}`);
      const opts=d.optionChain.result[0].options[0];
      const dte=Math.max(Math.round((exp-today)/86400),0);
      const T=Math.max(dte/365,1e-6);
      for (const [chain,isCall] of [[opts.calls,true],[opts.puts,false]]) {
        for (const o of (chain||[])) {
          const K=o.strike, iv=o.impliedVolatility, oi=o.openInterest||0;
          if (!iv||iv<.01||iv>3||oi<10||K<spot*.8||K>spot*1.2) continue;
          const g=bsGreeks(spot,K,T,r,q,iv,isCall);
          const sign=isCall?-1:1;
          rows.push({strike:K,dte,flag:isCall?'C':'P',iv,oi,
            ngex:sign*g.gamma*oi*100,
            nvanna:sign*g.vanna*oi*100,
            ncharm:sign*g.charm*oi*100,
            ndelta:sign*g.delta*oi*100});
        }
      }
    } catch {}
  }

  if (rows.length < 5) {
    setSimulatedGreeks(spot, ratio);
    return;
  }

  // Aggregate by strike
  const byStrike={};
  for (const r of rows) {
    const k=r.strike.toFixed(2);
    if (!byStrike[k]) byStrike[k]={strike:r.strike,ngex:0,nvanna:0,ncharm:0,ndelta:0,ivs:[],dtes:[]};
    byStrike[k].ngex+=r.ngex; byStrike[k].nvanna+=r.nvanna;
    byStrike[k].ncharm+=r.ncharm; byStrike[k].ndelta+=r.ndelta;
    byStrike[k].ivs.push(r.iv); byStrike[k].dtes.push(r.dte);
  }
  const strikes=Object.values(byStrike).sort((a,b)=>a.strike-b.strike);

  const gexTot=strikes.reduce((s,r)=>s+r.ngex,0);
  const vannaTot=strikes.reduce((s,r)=>s+r.nvanna,0);
  const charmTot=strikes.reduce((s,r)=>s+r.ncharm,0);
  const deltaTot=strikes.reduce((s,r)=>s+r.ndelta,0);

  // ATM IV
  const atm=strikes.reduce((b,r)=>Math.abs(r.strike-spot)<Math.abs(b.strike-spot)?r:b,strikes[0]);
  const atmIV=(atm.ivs.reduce((s,v)=>s+v,0)/atm.ivs.length*100).toFixed(1);

  // Gamma flip level
  let cumGex=0, flipStrike=null;
  for (const s of strikes.sort((a,b)=>a.strike-b.strike)) {
    const prev=cumGex; cumGex+=s.ngex;
    if (prev*cumGex<0) { flipStrike=s.strike; break; }
  }

  const esSpot=(spot*ratio).toFixed(0);
  const esFlip=flipStrike?(flipStrike*ratio).toFixed(0):'—';

  // Update KPIs
  document.getElementById('nav-price').textContent='$'+(spot*ratio).toFixed(2);
  document.getElementById('kpi-es').textContent=Number(esSpot).toLocaleString();
  const gexEl=document.getElementById('kpi-gex');
  gexEl.textContent=(gexTot>0?'▲ ':'▼ ')+Math.abs(gexTot).toLocaleString(undefined,{maximumFractionDigits:0});
  gexEl.style.color=gexTot>0?'var(--green)':'var(--red)';
  document.getElementById('kpi-gex-sub').textContent=gexTot>0?'Dealers long gamma':'Dealers short gamma';
  document.getElementById('kpi-vanna').textContent=vannaTot.toLocaleString(undefined,{maximumFractionDigits:0});
  document.getElementById('kpi-vanna-sub').textContent=vannaTot>0?'Bullish tilt':'Bearish tilt';
  document.getElementById('kpi-iv').textContent=atmIV+'%';
  document.getElementById('kpi-iv-sub').textContent='ATM SPY options';
  document.getElementById('kpi-flip').textContent='~'+esFlip;
  document.getElementById('kpi-charm').textContent=charmTot.toLocaleString(undefined,{maximumFractionDigits:0});
  document.getElementById('kpi-charm-sub').textContent=charmTot<0?'Sell pressure':'Buy pressure';

  // Greek cards
  const vanPct=Math.min(Math.abs(vannaTot)/Math.max(Math.abs(vannaTot),1)*100,100);
  document.getElementById('vanna-val').textContent=(vannaTot>0?'+':'')+vannaTot.toLocaleString(undefined,{maximumFractionDigits:0});
  document.getElementById('vanna-bar').style.width=vanPct+'%';
  document.getElementById('vanna-badge').textContent=vannaTot>0?'Bullish':'Bearish';
  document.getElementById('vanna-badge').className='badge '+(vannaTot>0?'badge-bull':'badge-bear');

  document.getElementById('gamma-val').textContent=(gexTot>0?'+':'')+gexTot.toLocaleString(undefined,{maximumFractionDigits:0});
  document.getElementById('gamma-bar').style.width='85%';
  document.getElementById('gamma-badge').textContent=gexTot>0?'Stabilizing':'Destabilizing';

  document.getElementById('charm-val').textContent=(charmTot>0?'+':'')+charmTot.toLocaleString(undefined,{maximumFractionDigits:0});
  document.getElementById('charm-bar').style.width='45%';
  document.getElementById('charm-badge').textContent=charmTot<0?'Headwind':'Tailwind';
  document.getElementById('charm-badge').className='badge '+(charmTot<0?'badge-bear':'badge-bull');

  document.getElementById('delta-val').textContent=(deltaTot>0?'+':'')+deltaTot.toLocaleString(undefined,{maximumFractionDigits:0});
  document.getElementById('delta-bar').style.width='60%';

  // Bias cards
  document.getElementById('bias-vanna-val').textContent=vannaTot>0?'Bullish — dips bought':'Bearish — rallies sold';
  document.getElementById('bias-gamma-val').textContent=gexTot>0?'Long — vol suppressed':'Short — vol amplified';
  document.getElementById('bias-charm-val').textContent=charmTot<0?'Minor sell pressure':'Minor buy support';

  // Charts
  const BG='#0a0d14', LINE='#161c28', DIM='#2a3448', WHITE='#ccdaee';
  const GREEN='#00d97e', RED='#f03d5f', CYAN='#00c8f0', AMBER='#f0a500';
  const FONT="'IBM Plex Mono',monospace";
  const baseLayout={paper_bgcolor:BG,plot_bgcolor:'#06080d',
    font:{family:FONT,color:DIM,size:9},
    xaxis:{showgrid:false,zeroline:false,tickfont:{color:DIM,size:8},linecolor:LINE},
    yaxis:{showgrid:false,zeroline:false,tickfont:{color:DIM,size:8},linecolor:LINE},
    margin:{l:44,r:10,t:16,b:32},showlegend:false,
    hoverlabel:{bgcolor:BG,bordercolor:LINE,font:{color:WHITE,size:9,family:FONT}}};

  // GEX chart
  const top5pos=strikes.filter(s=>s.ngex>0).sort((a,b)=>b.ngex-a.ngex).slice(0,5);
  const top5neg=strikes.filter(s=>s.ngex<0).sort((a,b)=>a.ngex-b.ngex).slice(0,5);
  const gexStrikes=[...top5pos,...top5neg].sort((a,b)=>a.strike-b.strike);
  Plotly.newPlot('gc-gex',[{
    type:'bar',x:gexStrikes.map(s=>(s.strike*ratio).toFixed(0)),
    y:gexStrikes.map(s=>s.ngex),
    marker:{color:gexStrikes.map(s=>s.ngex>0?GREEN:RED),line:{width:0}},
    hovertemplate:'ES %{x}<br>GEX: %{y:,.0f}<extra></extra>'
  }],{...baseLayout,
    shapes:[{type:'line',x0:0,x1:1,y0:0,y1:0,xref:'paper',line:{color:LINE,width:1}},
            {type:'line',x0:(spot*ratio).toFixed(0),x1:(spot*ratio).toFixed(0),y0:0,y1:1,yref:'paper',line:{color:WHITE,width:.8,dash:'dot'}}]
  },{responsive:true,displayModeBar:false});

  // Vanna profile
  Plotly.newPlot('gc-van',[{
    type:'scatter',x:strikes.map(s=>(s.strike*ratio).toFixed(0)),
    y:strikes.map(s=>s.nvanna),mode:'lines',
    fill:'tozeroy',fillcolor:'rgba(0,200,240,.05)',
    line:{color:DIM,width:1},
    hovertemplate:'ES %{x}<br>Vanna: %{y:,.0f}<extra></extra>'
  }],{...baseLayout,
    shapes:[{type:'line',x0:0,x1:1,y0:0,y1:0,xref:'paper',line:{color:LINE,width:1}},
            {type:'line',x0:(spot*ratio).toFixed(0),x1:(spot*ratio).toFixed(0),y0:0,y1:1,yref:'paper',line:{color:WHITE,width:.8,dash:'dot'}}]
  },{responsive:true,displayModeBar:false});

  // Gamma profile
  Plotly.newPlot('gc-gam',[{
    type:'scatter',x:strikes.map(s=>(s.strike*ratio).toFixed(0)),
    y:strikes.map(s=>s.ngex),mode:'lines',
    fill:'tozeroy',fillcolor:'rgba(0,217,126,.05)',
    line:{color:DIM,width:1},
    hovertemplate:'ES %{x}<br>Gamma: %{y:,.0f}<extra></extra>'
  }],{...baseLayout,
    shapes:[{type:'line',x0:0,x1:1,y0:0,y1:0,xref:'paper',line:{color:LINE,width:1}},
            {type:'line',x0:(spot*ratio).toFixed(0),x1:(spot*ratio).toFixed(0),y0:0,y1:1,yref:'paper',line:{color:WHITE,width:.8,dash:'dot'}}]
  },{responsive:true,displayModeBar:false});

  // Charm profile
  Plotly.newPlot('gc-ch',[{
    type:'scatter',x:strikes.map(s=>(s.strike*ratio).toFixed(0)),
    y:strikes.map(s=>s.ncharm),mode:'lines',
    fill:'tozeroy',fillcolor:'rgba(160,120,240,.05)',
    line:{color:DIM,width:1},
    hovertemplate:'ES %{x}<br>Charm: %{y:,.5f}<extra></extra>'
  }],{...baseLayout,
    shapes:[{type:'line',x0:0,x1:1,y0:0,y1:0,xref:'paper',line:{color:LINE,width:1}},
            {type:'line',x0:(spot*ratio).toFixed(0),x1:(spot*ratio).toFixed(0),y0:0,y1:1,yref:'paper',line:{color:WHITE,width:.8,dash:'dot'}}]
  },{responsive:true,displayModeBar:false});

  // Term structure — aggregate IV by DTE
  const byDte={};
  for (const ro of rows) {
    if (!byDte[ro.dte]) byDte[ro.dte]={calls:[],puts:[]};
    (ro.flag==='C'?byDte[ro.dte].calls:byDte[ro.dte].puts).push(ro.iv);
  }
  const dtes=Object.keys(byDte).map(Number).sort((a,b)=>a-b);
  const callIVs=dtes.map(d=>byDte[d].calls.length?byDte[d].calls.reduce((s,v)=>s+v,0)/byDte[d].calls.length*100:null);
  const putIVs=dtes.map(d=>byDte[d].puts.length?byDte[d].puts.reduce((s,v)=>s+v,0)/byDte[d].puts.length*100:null);
  Plotly.newPlot('gc-term',[
